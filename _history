" numlines=\"1\"></mutation><next><block type=\"gameSplash\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><value name=\"title\"><shadow type=\"text\"><field name=\"TEXT\"></field></shadow><block type=\"pokemon_lastText\"></block></value></block></next></block></statement><next><block type=\"controls_if\"><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"logic_negate\"><value name=\"BOOL\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"pokemon_isFainted\"><value name=\"mon\"><block type=\"variables_get\"><field name=\"VAR\" id=\"l1ig%*Mdt_%[^3EX^siq\">leafy</field></block></value></block></value></block></value><statement name=\"DO0\"><block type=\"typescript_statement\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" line0=\"pokemon.useMove(leafy, pyro, 0)\" numlines=\"1\"></mutation><next><block type=\"gameSplash\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><value name=\"title\"><shadow type=\"text\"><field name=\"TEXT\"></field></shadow><block type=\"pokemon_lastText\"></block></value></block></next></block></statement><next><block type=\"controls_if\"><value name=\"IF0\"><shadow type=\"logic_boolean\"><field name=\"BOOL\">TRUE</field></shadow><block type=\"pokemon_randomEncounter\"><value name=\"percent\"><shadow type=\"math_number\"><field name=\"NUM\">25</field></shadow></value></block></value><statement name=\"DO0\"><block type=\"gameSplash\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><value name=\"title\"><shadow type=\"text\"><field name=\"TEXT\">Encontro selvagem!</field></shadow></value></block></statement><next><block type=\"variables_set\"><field name=\"VAR\" id=\"^t(u1%eJw7@RS@?2En4*\">captured</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"pokemon_throwBall\"><value name=\"bag\"><block type=\"variables_get\"><field name=\"VAR\" id=\"Zm:N$qDvgn)~P6pJOf2o\">bag</field></block></value><value name=\"target\"><block type=\"variables_get\"><field name=\"VAR\" id=\"l1ig%*Mdt_%[^3EX^siq\">leafy</field></block></value><value name=\"bonus\"><shadow type=\"math_number\"><field name=\"NUM\">10</field></shadow></value></block></value><next><block type=\"gameSplash\"><mutation xmlns=\"http://www.w3.org/1999/xhtml\" _expanded=\"0\" _input_init=\"true\"></mutation><value name=\"title\"><shadow type=\"text\"><field name=\"TEXT\"></field></shadow><block type=\"pokemon_lastText\"></block></value></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"","README.md":" ","assets.json":"","pokemon.ts":"/**\n * Extensão base para jogos estilo monster-catching no MakeCode Arcade\n */\n//% color=\"#4B7BEC\" weight=90 icon=\"\\uf1b0\" block=\"Pokemon Engine\"\nnamespace pokemon {\n\n    //% blockNamespace=pokemon\n    export enum ElementType {\n        //% block=\"normal\"\n        Normal = 0,\n        //% block=\"fogo\"\n        Fire = 1,\n        //% block=\"água\"\n        Water = 2,\n        //% block=\"planta\"\n        Grass = 3,\n        //% block=\"elétrico\"\n        Electric = 4\n    }\n\n    //% blockNamespace=pokemon\n    export enum MoveKind {\n        //% block=\"dano\"\n        Damage = 0,\n        //% block=\"cura\"\n        Heal = 1,\n        //% block=\"status\"\n        Status = 2\n    }\n\n    //% blockNamespace=pokemon\n    export enum StatusEffect {\n        //% block=\"nenhum\"\n        None = 0,\n        //% block=\"queimadura\"\n        Burn = 1,\n        //% block=\"veneno\"\n        Poison = 2,\n        //% block=\"paralisia\"\n        Paralysis = 3,\n        //% block=\"sono\"\n        Sleep = 4\n    }\n\n    export class Move {\n        name: string\n        power: number\n        accuracy: number\n        maxPP: number\n        pp: number\n        element: ElementType\n        kind: MoveKind\n        effectStatus: StatusEffect\n        effectChance: number\n\n        constructor(\n            name: string,\n            power: number,\n            accuracy: number,\n            maxPP: number,\n            element: ElementType,\n            kind: MoveKind,\n            effectStatus: StatusEffect = StatusEffect.None,\n            effectChance: number = 0\n        ) {\n            this.name = name\n            this.power = power\n            this.accuracy = accuracy\n            this.maxPP = maxPP\n            this.pp = maxPP\n            this.element = element\n            this.kind = kind\n            this.effectStatus = effectStatus\n            this.effectChance = effectChance\n        }\n    }\n\n    export class Creature {\n        name: string\n        level: number\n        exp: number\n        element: ElementType\n\n        maxHp: number\n        hp: number\n        attack: number\n        defense: number\n        speed: number\n\n        status: StatusEffect\n        sleepTurns: number\n\n        moves: Move[]\n\n        constructor(\n            name: string,\n            level: number,\n            maxHp: number,\n            attack: number,\n            defense: number,\n            speed: number,\n            element: ElementType\n        ) {\n            this.name = name\n            this.level = level\n            this.exp = 0\n            this.element = element\n\n            this.maxHp = maxHp\n            this.hp = maxHp\n            this.attack = attack\n            this.defense = defense\n            this.speed = speed\n\n            this.status = StatusEffect.None\n            this.sleepTurns = 0\n\n            this.moves = []\n        }\n    }\n\n    export class Bag {\n        balls: number\n        potions: number\n        superPotions: number\n\n        constructor() {\n            this.balls = 5\n            this.potions = 3\n            this.superPotions = 1\n        }\n    }\n\n    let _lastText = \"\"\n\n    function clamp(value: number, min: number, max: number): number {\n        if (value < min) return min\n        if (value > max) return max\n        return value\n    }\n\n    function randomPercent(): number {\n        return randint(1, 100)\n    }\n\n    function isTypeStrongAgainst(attacker: ElementType, defender: ElementType): boolean {\n        return (\n            (attacker == ElementType.Fire && defender == ElementType.Grass) ||\n            (attacker == ElementType.Water && defender == ElementType.Fire) ||\n            (attacker == ElementType.Grass && defender == ElementType.Water) ||\n            (attacker == ElementType.Electric && defender == ElementType.Water)\n        )\n    }\n\n    function isTypeWeakAgainst(attacker: ElementType, defender: ElementType): boolean {\n        return (\n            (attacker == ElementType.Fire && defender == ElementType.Water) ||\n            (attacker == ElementType.Water && defender == ElementType.Grass) ||\n            (attacker == ElementType.Grass && defender == ElementType.Fire) ||\n            (attacker == ElementType.Water && defender == ElementType.Electric)\n        )\n    }\n\n    function applyEndTurnStatus(mon: Creature) {\n        if (mon.hp <= 0) return\n\n        if (mon.status == StatusEffect.Burn) {\n            mon.hp -= Math.max(1, Math.idiv(mon.maxHp, 16))\n            if (mon.hp < 0) mon.hp = 0\n        } else if (mon.status == StatusEffect.Poison) {\n            mon.hp -= Math.max(1, Math.idiv(mon.maxHp, 12))\n            if (mon.hp < 0) mon.hp = 0\n        }\n    }\n\n    function tryApplyMoveEffect(attacker: Creature, defender: Creature, move: Move) {\n        if (move.effectStatus == StatusEffect.None) return\n        if (defender.status != StatusEffect.None) return\n        if (move.effectChance <= 0) return\n\n        if (Math.percentChance(move.effectChance)) {\n            defender.status = move.effectStatus\n            if (move.effectStatus == StatusEffect.Sleep) {\n                defender.sleepTurns = randint(1, 3)\n            }\n        }\n    }\n\n    function canCreatureAct(mon: Creature): boolean {\n        if (mon.hp <= 0) {\n            _lastText = mon.name + \" está fora de combate.\"\n            return false\n        }\n\n        if (mon.status == StatusEffect.Sleep) {\n            if (mon.sleepTurns > 0) {\n                mon.sleepTurns--\n                _lastText = mon.name + \" está dormindo.\"\n                return false\n            } else {\n                mon.status = StatusEffect.None\n            }\n        }\n\n        if (mon.status == StatusEffect.Paralysis) {\n            if (Math.percentChance(25)) {\n                _lastText = mon.name + \" está paralisado e não conseguiu agir.\"\n                return false\n            }\n        }\n\n        return true\n    }\n\n    //% block=\"criar criatura %name nível %level hp %maxHp atk %attack def %defense spd %speed tipo %element\"\n    //% group=\"Criaturas\"\n    export function createCreature(\n        name: string,\n        level: number,\n        maxHp: number,\n        attack: number,\n        defense: number,\n        speed: number,\n        element: ElementType\n    ): Creature {\n        return new Creature(name, level, maxHp, attack, defense, speed, element)\n    }\n\n    //% block=\"criar golpe %name poder %power precisão %accuracy pp %pp tipo %element\"\n    //% group=\"Golpes\"\n    export function createMove(\n        name: string,\n        power: number,\n        accuracy: number,\n        pp: number,\n        element: ElementType\n    ): Move {\n        return new Move(name, power, accuracy, pp, element, MoveKind.Damage, StatusEffect.None, 0)\n    }\n\n    //% block=\"criar golpe de status %name precisão %accuracy pp %pp aplica %status com chance %chance\"\n    //% group=\"Golpes\"\n    export function createStatusMove(\n        name: string,\n        accuracy: number,\n        pp: number,\n        status: StatusEffect,\n        chance: number\n    ): Move {\n        return new Move(name, 0, accuracy, pp, ElementType.Normal, MoveKind.Status, status, chance)\n    }\n\n    //% block=\"criar golpe de cura %name cura %power precisão %accuracy pp %pp\"\n    //% group=\"Golpes\"\n    export function createHealMove(\n        name: string,\n        power: number,\n        accuracy: number,\n        pp: number\n    ): Move {\n        return new Move(name, power, accuracy, pp, ElementType.Normal, MoveKind.Heal, StatusEffect.None, 0)\n    }\n\n    //% block=\"ensinar golpe %move para %mon\"\n    //% group=\"Golpes\"\n    export function teachMove(mon: Creature, move: Move): boolean {\n        if (mon.moves.length >= 4) {\n            _lastText = mon.name + \" já tem 4 golpes.\"\n            return false\n        }\n\n        mon.moves.push(move)\n        _lastText = mon.name + \" aprendeu \" + move.name + \".\"\n        return true\n    }\n\n    //% block=\"restaurar criatura %mon\"\n    //% group=\"Criaturas\"\n    export function healFull(mon: Creature) {\n        mon.hp = mon.maxHp\n        mon.status = StatusEffect.None\n        mon.sleepTurns = 0\n\n        for (let i = 0; i < mon.moves.length; i++) {\n            mon.moves[i].pp = mon.moves[i].maxPP\n        }\n\n        _lastText = mon.name + \" foi restaurado.\"\n    }\n\n    //% block=\"hp atual de %mon\"\n    //% group=\"Leitura\"\n    export function hp(mon: Creature): number {\n        return mon.hp\n    }\n\n    //% block=\"hp máximo de %mon\"\n    //% group=\"Leitura\"\n    export function maxHp(mon: Creature): number {\n        return mon.maxHp\n    }\n\n    //% block=\"nível de %mon\"\n    //% group=\"Leitura\"\n    export function level(mon: Creature): number {\n        return mon.level\n    }\n\n    //% block=\"%mon está fora de combate\"\n    //% group=\"Leitura\"\n    export function isFainted(mon: Creature): boolean {\n        return mon.hp <= 0\n    }\n\n    //% block=\"nome de %mon\"\n    //% group=\"Leitura\"\n    export function creatureName(mon: Creature): string {\n        return mon.name\n    }\n\n    //% block=\"multiplicador de tipo de %attackType contra %defenseType\"\n    //% group=\"Batalha\"\n    export function typeMultiplier(attackType: ElementType, defenseType: ElementType): number {\n        if (isTypeStrongAgainst(attackType, defenseType)) return 2\n        if (isTypeWeakAgainst(attackType, defenseType)) return 0.5\n        return 1\n    }\n\n    //% block=\"usar golpe índice %moveIndex de %attacker em %defender\"\n    //% group=\"Batalha\"\n    export function useMove(attacker: Creature, defender: Creature, moveIndex: number): number {\n        if (attacker == null || defender == null) {\n            _lastText = \"Criatura inválida.\"\n            return 0\n        }\n\n        if (moveIndex < 0 || moveIndex >= attacker.moves.length) {\n            _lastText = \"Golpe inválido.\"\n            return 0\n        }\n\n        if (!canCreatureAct(attacker)) {\n            return 0\n        }\n\n        let move = attacker.moves[moveIndex]\n\n        if (move.pp <= 0) {\n            _lastText = move.name + \" sem PP.\"\n            return 0\n        }\n\n        move.pp--\n\n        if (!Math.percentChance(clamp(move.accuracy, 1, 100))) {\n            _lastText = attacker.name + \" errou \" + move.name + \".\"\n            return 0\n        }\n\n        if (move.kind == MoveKind.Heal) {\n            let healAmount = Math.max(1, move.power + Math.idiv(attacker.level, 2))\n            attacker.hp += healAmount\n            if (attacker.hp > attacker.maxHp) attacker.hp = attacker.maxHp\n            _lastText = attacker.name + \" recuperou \" + healAmount + \" HP com \" + move.name + \".\"\n            return -healAmount\n        }\n\n        if (move.kind == MoveKind.Status) {\n            tryApplyMoveEffect(attacker, defender, move)\n            _lastText = attacker.name + \" usou \" + move.name + \".\"\n            return 0\n        }\n\n        let multiplier = typeMultiplier(move.element, defender.element)\n        let stab = 1\n        if (move.element == attacker.element) stab = 1.2\n\n        let variance = randint(85, 100)\n        let attackStat = attacker.attack + attacker.level\n        let defenseStat = Math.max(1, defender.defense)\n\n        let base = Math.max(1, attackStat + move.power - Math.idiv(defenseStat, 2))\n        let damage = Math.idiv(base * variance, 100)\n\n        if (multiplier == 2) {\n            damage *= 2\n        } else if (multiplier == 0.5) {\n            damage = Math.max(1, Math.idiv(damage, 2))\n        }\n\n        if (stab > 1) {\n            damage = Math.max(1, Math.idiv(damage * 12, 10))\n        }\n\n        if (attacker.status == StatusEffect.Burn) {\n            damage = Math.max(1, Math.idiv(damage * 8, 10))\n        }\n\n        defender.hp -= Math.max(1, damage)\n        if (defender.hp < 0) defender.hp = 0\n\n        tryApplyMoveEffect(attacker, defender, move)\n\n        _lastText = attacker.name + \" usou \" + move.name + \" e causou \" + damage + \" de dano.\"\n\n        applyEndTurnStatus(attacker)\n        applyEndTurnStatus(defender)\n\n        if (defender.hp <= 0) {\n            _lastText = _lastText + \" \" + defender.name + \" caiu.\"\n        }\n\n        return damage\n    }\n\n    //% block=\"aplicar status %status em %mon\"\n    //% group=\"Batalha\"\n    export function setStatus(mon: Creature, status: StatusEffect) {\n        mon.status = status\n        if (status == StatusEffect.Sleep) {\n            mon.sleepTurns = randint(1, 3)\n        } else {\n            mon.sleepTurns = 0\n        }\n        _lastText = mon.name + \" agora está com status.\"\n    }\n\n    //% block=\"velocidade de %a é maior que de %b\"\n    //% group=\"Batalha\"\n    export function goesFirst(a: Creature, b: Creature): boolean {\n        return a.speed >= b.speed\n    }\n\n    //% block=\"dar %amount de experiência para %mon\"\n    //% group=\"Progressão\"\n    export function giveExp(mon: Creature, amount: number) {\n        mon.exp += Math.max(0, amount)\n        _lastText = mon.name + \" ganhou \" + amount + \" EXP.\"\n    }\n\n    //% block=\"tentar subir nível de %mon\"\n    //% group=\"Progressão\"\n    export function tryLevelUp(mon: Creature): boolean {\n        let needed = mon.level * 10\n        if (mon.exp < needed) return false\n\n        mon.exp -= needed\n        mon.level += 1\n        mon.maxHp += 3\n        mon.attack += 2\n        mon.defense += 2\n        mon.speed += 1\n        mon.hp = mon.maxHp\n\n        _lastText = mon.name + \" subiu para o nível \" + mon.level + \".\"\n        return true\n    }\n\n    //% block=\"criar bolsa\"\n    //% group=\"Itens\"\n    export function createBag(): Bag {\n        return new Bag()\n    }\n\n    //% block=\"adicionar %amount pokebolas na %bag\"\n    //% group=\"Itens\"\n    export function addBalls(bag: Bag, amount: number) {\n        bag.balls += Math.max(0, amount)\n    }\n\n    //% block=\"adicionar %amount poções na %bag\"\n    //% group=\"Itens\"\n    export function addPotions(bag: Bag, amount: number) {\n        bag.potions += Math.max(0, amount)\n    }\n\n    //% block=\"usar poção em %mon da %bag\"\n    //% group=\"Itens\"\n    export function usePotion(bag: Bag, mon: Creature): boolean {\n        if (bag.potions <= 0) {\n            _lastText = \"Sem poções.\"\n            return false\n        }\n\n        if (mon.hp <= 0) {\n            _lastText = \"Não pode usar em criatura fora de combate.\"\n            return false\n        }\n\n        bag.potions--\n        mon.hp += 20\n        if (mon.hp > mon.maxHp) mon.hp = mon.maxHp\n\n        _lastText = mon.name + \" recuperou HP com poção.\"\n        return true\n    }\n\n    //% block=\"usar super poção em %mon da %bag\"\n    //% group=\"Itens\"\n    export function useSuperPotion(bag: Bag, mon: Creature): boolean {\n        if (bag.superPotions <= 0) {\n            _lastText = \"Sem super poções.\"\n            return false\n        }\n\n        if (mon.hp <= 0) {\n            _lastText = \"Não pode usar em criatura fora de combate.\"\n            return false\n        }\n\n        bag.superPotions--\n        mon.hp += 50\n        if (mon.hp > mon.maxHp) mon.hp = mon.maxHp\n\n        _lastText = mon.name + \" recuperou muito HP.\"\n        return true\n    }\n\n    //% block=\"chance de captura de %target com bônus %bonus\"\n    //% group=\"Captura\"\n    export function captureChance(target: Creature, bonus: number): number {\n        if (target.hp <= 0) return 100\n\n        let missingHp = target.maxHp - target.hp\n        let hpPart = Math.idiv(missingHp * 60, Math.max(1, target.maxHp))\n        let levelPart = Math.max(0, 25 - target.level)\n        let statusPart = 0\n\n        if (target.status == StatusEffect.Sleep) statusPart = 20\n        else if (target.status == StatusEffect.Paralysis) statusPart = 12\n        else if (target.status == StatusEffect.Burn || target.status == StatusEffect.Poison) statusPart = 8\n\n        let total = hpPart + levelPart + statusPart + bonus\n        return clamp(total, 5, 95)\n    }\n\n    //% block=\"tentar capturar %target com bônus %bonus\"\n    //% group=\"Captura\"\n    export function tryCapture(target: Creature, bonus: number): boolean {\n        let chance = captureChance(target, bonus)\n        let ok = Math.percentChance(chance)\n\n        if (ok) {\n            _lastText = target.name + \" foi capturado.\"\n        } else {\n            _lastText = target.name + \" escapou.\"\n        }\n\n        return ok\n    }\n\n    //% block=\"arremessar pokebola da %bag em %target com bônus %bonus\"\n    //% group=\"Captura\"\n    export function throwBall(bag: Bag, target: Creature, bonus: number): boolean {\n        if (bag.balls <= 0) {\n            _lastText = \"Sem pokebolas.\"\n            return false\n        }\n\n        bag.balls--\n        return tryCapture(target, bonus)\n    }\n\n    //% block=\"encontro aleatório com chance %percent \\\\%\"\n    //% group=\"Mapa\"\n    export function randomEncounter(percent: number): boolean {\n        return Math.percentChance(clamp(percent, 0, 100))\n    }\n\n    //% block=\"texto da última ação\"\n    //% group=\"Leitura\"\n    export function lastText(): string {\n        return _lastText\n    }\n\n    //% block=\"resumo de %mon\"\n    //% group=\"Leitura\"\n    export function summary(mon: Creature): string {\n        return mon.name +\n            \" Lv\" + mon.level +\n            \" HP \" + mon.hp + \"/\" + mon.maxHp +\n            \" ATK \" + mon.attack +\n            \" DEF \" + mon.defense +\n            \" SPD \" + mon.speed\n    }\n\n    //% block=\"pp do golpe índice %moveIndex de %mon\"\n    //% group=\"Leitura\"\n    export function movePP(mon: Creature, moveIndex: number): number {\n        if (moveIndex < 0 || moveIndex >= mon.moves.length) return 0\n        return mon.moves[moveIndex].pp\n    }\n\n    //% block=\"nome do golpe índice %moveIndex de %mon\"\n    //% group=\"Leitura\"\n    export function moveName(mon: Creature, moveIndex: number): string {\n        if (moveIndex < 0 || moveIndex >= mon.moves.length) return \"\"\n        return mon.moves[moveIndex].name\n    }\n}","pxt.json":"{\n    \"name\": \"pokemon extension\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"pokemon.ts\"\n    ],\n    \"preferredEditor\": \"blocksprj\"\n}\n"}}],"shares":[],"lastSaveTime":1774187525213}